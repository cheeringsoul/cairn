	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSCalendarsUsageDescription</key>
	<string>Used to add events you ask the AI to schedule (meetings, reminders) to your calendar.</string>
	<key>NSCalendarsWriteOnlyAccessUsageDescription</key>
	<string>Used to add events you ask the AI to schedule to your calendar.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Used to answer location-aware questions (e.g. local weather, nearby places) when you ask the AI.</string>
